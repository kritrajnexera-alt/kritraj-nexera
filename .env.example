# Contact form — Resend email
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# Email that receives enquiries
CONTACT_TO=kritrajnexera@gmail.com

# Verified sender address.
# Testing: onboarding@resend.dev (works without domain verification)
# Production: noreply@yourdomain.com (after verifying your domain in Resend)
CONTACT_FROM=onboarding@resend.dev

# Override the site URL for non-production deployments (preview/staging)
# Defaults to https://kritrajnexera.com when unset
NEXT_PUBLIC_SITE_URL=https://kritrajnexera.com

# Supabase Postgres (Vercel Marketplace) — auto-provisioned connection string
# Enable via Vercel → Storage → Marketplace Database Providers → Supabase
# POSTGRES_URL is auto-set. DATABASE_URL also works as fallback for local dev.
POSTGRES_URL=postgres://...

# Upstash Redis — serverless rate limiting
# Create a free Redis database at https://console.upstash.com
# Or use the Vercel-Upstash integration: Vercel → Storage → Marketplace → Upstash
# These are auto-set if using the integration; otherwise manually add to Vercel env vars.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Live Demo — n8n webhook URL
# Set this to your n8n webhook endpoint for the live demo flow.
# If unset, the demo falls back to simulated mode.
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/demo
